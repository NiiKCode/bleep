<div class="w-full">

  <!-- SECTION 1: Hero -->
  <section class="h-[65vh] sm:min-h-screen lg:min-h-[125vh] flex items-center justify-center bg-cover bg-center overflow-hidden pt-5 sm:pt-20 md:pt-24"
    style="background-image: url('<%= asset_path('homepage_background.png') %>');">

    <div class="w-full px-4 sm:px-6">
      <div class="relative z-10 w-full max-w-5xl mx-auto text-center -mt-2 sm:-mt-6 md:-mt-4 lg:-mt-27">

        <h1 class="font-futura font-bold tracking-tight text-center leading-[0.82] mx-auto max-w-[90vw]">
          <span class="block text-[clamp(7rem,20vw,13rem)] text-center">
            <span class="inline-block">
              BE<span class="relative inline-block">
                <span class="relative inline-block">
                  AT
                  <span style="
                    position: absolute;
                    left: 0;
                    top: 0.3em;
                    width: 100%;
                    height: 0.18em;
                    background: #ec4899;
                    transform: rotate(6deg);
                    z-index: 20;
                    pointer-events: none;
                  "></span>
                </span>
              </span>
            </span>
          </span>

          <span class="block text-[clamp(7rem,20vw,13rem)] -mt-1">YOUR</span>
          <span class="block text-[clamp(7rem,20vw,13rem)] -mt-1">BEST</span>
        </h1>

        <p class="mt-2 sm:mt-3 text-[clamp(1.7rem,4.9vw,2.5rem)] font-futura font-extrabold italic leading-[1.3] max-w-lg mx-auto text-center">
          <span class="block">Go solo or with a</span>
          <span class="block">friend, track your</span>
          <span class="block">fitness and beat</span>
          <span class="block">your best</span>
        </p>

      </div>
    </div>
  </section>

  <!-- SECTION 2: Directory -->
  <section id="directory" class="bg-white px-6 py-4">
    <div class="w-full max-w-md mx-auto lg:max-w-xl">

      <%= form_with url: root_path, method: :get, local: true do %>

        <!-- ✨ Spacing wrapper -->
        <div class="space-y-0.5">

          <!-- City -->
          <%= render DropdownComponent.new(
            name: :city,
            options: @cities,
            selected: @selected_city || @cities.first
          ) %>

          <!-- Location -->
          <%= render DropdownComponent.new(
            name: :location_id,
            options: @locations,
            selected: @locations.find { |l| l.id == @selected_location_id } || @locations.first,
            value_method: :id,
            label_method: :name
          ) %>

          <!-- Date (🔥 improved format) -->
          <%= render DropdownComponent.new(
            name: :date,
            options: @available_dates.map do |d|
              [
                "#{d.strftime('%a')} #{d.day.ordinalize} #{d.strftime('%b %Y')}",
                d
              ]
            end,
            selected: @available_dates.find { |d| d == @selected_date } || @available_dates.first
          ) %>

          <!-- Session Type -->
          <%= render DropdownComponent.new(
            name: :session_type_id,
            options: @available_session_types,
            selected: @available_session_types.find { |s| s.id == @selected_session_type_id } || @available_session_types.first,
            value_method: :id,
            label_method: :title
          ) %>

        </div>

      <% end %>

      <!-- Results -->
      <div class="pt-4 space-y-3">
        <%= render "sessions/results",
            scheduled_sessions: @scheduled_sessions,
            time_slots: @time_slots %>
      </div>

    </div>
  </section>

  <!-- SECTION 3: Footer -->
  <section class="px-6 py-8 flex items-end">
    <div class="w-full max-w-md mx-auto text-center space-y-6">

      <!-- Footer links -->
      <div class="text-m font-futura text-gray-700">
        <span>Privacy</span>
        <span class="px-2">|</span>
        <span>Terms</span>
        <span class="px-2">|</span>
        <span>Company Info</span>
      </div>

    </div>
  </section>

</div>
