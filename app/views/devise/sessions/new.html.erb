<div class="max-w-md mx-auto px-6 py-10">

  <!-- Log In -->
  <h2 class="text-3xl font-extrabold mb-6">
    Log In
  </h2>

  <%= form_for(resource,
      as: resource_name,
      url: session_path(resource_name),
      html: { data: { turbo: false } }) do |f| %>

    <div class="mb-4">
      <%= f.label :email, class: "block font-semibold mb-1" %>
      <%= f.email_field :email,
            autofocus: true,
            class: "w-full border-b border-black bg-transparent focus:outline-none py-2" %>
    </div>

    <div class="mb-6">
      <%= f.label :password, class: "block font-semibold mb-1" %>
      <%= f.password_field :password,
            class: "w-full border-b border-black bg-transparent focus:outline-none py-2" %>
    </div>

    <%= f.submit "Log In",
          class: "w-full py-3 border-2 border-black font-bold" %>

  <% end %>

  <!-- Divider -->
  <div class="border-t my-10"></div>

  <!-- Sign Up -->
  <h2 class="text-3xl font-extrabold mb-6">
    Sign Up
  </h2>

  <%= form_for(User.new,
        url: registration_path(:user)) do |f| %>

    <div class="mb-4">
      <%= f.label :first_name, class: "block font-semibold mb-1" %>
      <%= f.text_field :first_name,
            class: "w-full border-b border-black bg-transparent focus:outline-none py-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :last_name, class: "block font-semibold mb-1" %>
      <%= f.text_field :last_name,
            class: "w-full border-b border-black bg-transparent focus:outline-none py-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :date_of_birth, class: "block font-semibold mb-1" %>
      <%= f.date_field :date_of_birth,
            class: "w-full border-b border-black bg-transparent focus:outline-none py-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :email, class: "block font-semibold mb-1" %>
      <%= f.email_field :email,
            class: "w-full border-b border-black bg-transparent focus:outline-none py-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, class: "block font-semibold mb-1" %>
      <%= f.password_field :password,
            class: "w-full border-b border-black bg-transparent focus:outline-none py-2" %>
    </div>

    <div class="mb-6">
      <%= f.label :password_confirmation, class: "block font-semibold mb-1" %>
      <%= f.password_field :password_confirmation,
            class: "w-full border-b border-black bg-transparent focus:outline-none py-2" %>
    </div>

    <%= f.submit "Sign Up",
          class: "w-full py-3 border-2 border-black font-bold" %>

  <% end %>

</div>
