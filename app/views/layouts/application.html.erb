<!DOCTYPE html>
<html>
  <head>
    <title>BLEEP</title>

    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- CSS -->
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <!-- JS -->
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white text-gray-900 m-0 p-0 overflow-x-hidden">

    <!-- ✅ NAVBAR -->
    <header class="w-full bg-white/80 backdrop-blur-md">
      <div class="w-full max-w-7xl mx-auto px-6 py-6 flex items-center justify-between">

        <!-- Logo -->
        <div class="font-bold text-2xl tracking-tight">
          BLEEP
        </div>

        <!-- Account -->
        <%= render "shared/account_menu" %>

      </div>
    </header>

    <!-- ✅ MAIN CONTENT -->
    <main class="w-full">

      <%# If page is full-bleed, skip container %>
      <% if content_for?(:full_bleed) %>
        <%= yield %>
      <% else %>
        <%= render "shared/narrow_container" do %>
          <%= yield %>
        <% end %>
      <% end %>

    </main>

    <!-- ✅ FOOTER -->
    <%= render "shared/footer" %>

  </body>
</html>
