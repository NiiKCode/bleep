<div class="flex items-center justify-end">

  <% if user_signed_in? %>

    <!-- Clean initials (no circle) -->
    <%= link_to edit_user_registration_path,
          class: "font-bold text-lg hover:opacity-70 transition" do %>
      <%= current_user.initials %>
    <% end %>

  <% else %>

    <!-- Enter icon -->
    <%= link_to new_user_session_path,
          class: "hover:opacity-70 transition" do %>

      <svg xmlns="http://www.w3.org/2000/svg"
           class="w-7 h-7"
           fill="none"
           viewBox="0 0 24 24"
           stroke="currentColor"
           stroke-width="2">
        <path stroke-linecap="round"
              stroke-linejoin="round"
              d="M16 3h5v18h-5M10 17l5-5-5-5M15 12H3" />
      </svg>

    <% end %>

  <% end %>

</div>
