<!-- SECTION 3: Footer -->
<section class="px-6 pt-1 pb-6">
  <div class="w-full max-w-md mx-auto text-center space-y-6">

    <% if user_signed_in? %>
      <div class="flex justify-center">
        <%= button_to destroy_user_session_path,
              method: :delete,
              data: { turbo: false },
              class: "flex items-center gap-3 text-black hover:opacity-60 transition" do %>

          <!-- Logout Icon -->
          <svg xmlns="http://www.w3.org/2000/svg"
               class="w-6 h-6"
               fill="none"
               viewBox="0 0 24 24"
               stroke="currentColor"
               stroke-width="2">

            <path d="M4 4v16M4 4h6M4 20h6"
                  stroke-linecap="round"
                  stroke-linejoin="round"/>

            <path d="M14 8l4 4-4 4M18 12H8"
                  stroke-linecap="round"
                  stroke-linejoin="round"/>
          </svg>

          <span class="text-base font-medium">Logout</span>
        <% end %>
      </div>
    <% end %>

    <!-- Footer links -->
    <div class="text-base font-futura text-gray-700">
      <span>Privacy</span>
      <span class="px-2">|</span>
      <span>Terms</span>
      <span class="px-2">|</span>
      <span>Company Info</span>
    </div>

  </div>
</section>
