<%= render SectionComponent.new(title: "Friends", open: false) do %>

  <div data-controller="friend-select">

    <!-- SEARCH -->
    <div>
      <label class="text-sm font-semibold mb-2 block">
        Search by email
      </label>

      <div class="border rounded-2xl px-4 py-3 bg-gray-50">
        <%= text_field_tag :friend_email,
              nil,
              class: "w-full text-lg bg-transparent focus:outline-none",
              placeholder: "Start typing email...",
              data: {
                action: "input->friend-select#search",
                friend_select_target: "email"
              } %>
      </div>
    </div>

    <!-- FRIEND LIST -->
    <div class="space-y-3 pt-2">

      <h3 class="text-lg font-bold">Your friends</h3>

      <% current_user.all_friends.each do |friend| %>
        <div class="bg-gray-100 rounded-2xl px-4 py-3">
          <div class="font-semibold"><%= friend.email %></div>
        </div>
      <% end %>

    </div>

  </div>

<% end %>
